# ---- Anthropic (server-side only; NEVER expose to the client) ----
ANTHROPIC_API_KEY=your-anthropic-api-key
# Model slug used for both insight analysis and the companion chat.
ANTHROPIC_MODEL=your-anthropic-model

# ---- Supabase (public anon key is safe to ship; RLS protects all rows) ----
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional: set to 1 to short-circuit external calls in E2E/dev demos.
# NEXT_PUBLIC_E2E=0
